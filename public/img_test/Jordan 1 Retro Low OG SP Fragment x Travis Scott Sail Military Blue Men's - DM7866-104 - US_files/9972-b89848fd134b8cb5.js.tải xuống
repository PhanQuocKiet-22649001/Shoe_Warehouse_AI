fragment AdProductDetailsFragment on Product {
  __typename
  id
  favorite
  urlKey
  productCategory
  primaryCategory
  contentGroup
  brand
  name
  model
  listingType
  lockBuying
  lockSelling
  title
  gender
  browseVerticals
  uuid
  sizeDescriptor
  market(currencyCode: $currencyCode) {
    ...AdMarketFragment
  }
  media {
    smallImageUrl
    imageUrl
    thumbUrl
  }
  variants {
    id
    hidden
    sizeChart {
      baseSize
      baseType
      displayOptions {
        size
        type
      }
    }
    variantTraits: traits {
      size
      sizeDescriptor
    }
  }
  productTraits: traits(filterTypes: [RELEASE_DATE, RETAIL_PRICE]) {
    name
    value
  }
}

fragment AdMarketFragment on Market {
  currencyCode
  state(country: $countryCode, market: $marketName) {
    askServiceLevels {
      expressExpedited {
        count
        lowest {
          amount
          inventoryType
        }
      }
      expressStandard {
        count
        lowest {
          amount
          inventoryType
        }
      }
      expressNextDay {
        count
        lowest {
          amount
          inventoryType
        }
      }
    }
    lowestAsk {
      amount
      updatedAt
    }
    highestBid {
      amount
      updatedAt
    }
  }
  statistics {
    lastSale {
      amount
    }
    last72Hours {
      salesCount
    }
    annual {
      salesCount
    }
    last90Days {
      averagePrice
      salesCount
    }
  }
}

fragment AdVariantFragment on Variant {
  __typename
  id
  favorite
  sizeChart {
    baseSize
    baseType
    displayOptions {
      size
      type
    }
  }
  variantTraits: traits {
    size
    sizeDescriptor
  }
  product {
    ...AdProductDetailsFragment
  }
  market(currencyCode: $currencyCode) {
    ...AdMarketFragment
  }
}

query FetchSponsoredCarouselAds($id: String, $countryCode: String!, $currencyCode: CurrencyCode!, $limit: Int!, $marketName: String, $page: Int!, $preferences: PreferencesInput) {
  productCollection(id: $id) {
    tileType
    priceType
    footnotesType
    trackingEvent
    helpMessage
    ...AdsResultsFragment
    seeAllCTA {
      title
      url
      urlType
    }
